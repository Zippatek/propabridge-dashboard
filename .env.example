# ─── Customer auth (NextAuth) ───────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# openssl rand -base64 32
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── propabridge-backend (Node/Express api-gateway on Cloud Run) ────────────
# Base URL used by customer-side client code AND admin-side server proxy.
PROPA_BACKEND_BASE=https://propabridge-api-gateway-480235407496.us-central1.run.app
NEXT_PUBLIC_PROPA_BACKEND_BASE=https://propabridge-api-gateway-480235407496.us-central1.run.app

# Optional admin token for protected backend admin endpoints (KYC/fraud).
# Backend reads x-admin-token header.
PROPA_BACKEND_ADMIN_TOKEN=

# ─── propabridge-adk (FastAPI AI service on Cloud Run) ──────────────────────
# Used ONLY by the admin section.
PROPA_ADK_BASE=https://propabridge-adk-d7apfb4v6q-uc.a.run.app
PROPA_ADK_ADMIN_KEY=

# ─── /admin/* dashboard login ───────────────────────────────────────────────
# Single-secret guarding /admin/*. Should match PROPA_ADK_ADMIN_KEY so a
# successful login can also call the adk admin API.
ADMIN_DASHBOARD_KEY=
