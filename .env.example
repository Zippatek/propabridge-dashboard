# ─── Customer auth (NextAuth) ───────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# openssl rand -base64 32
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── propabridge-backend (Node/Express api-gateway on Cloud Run) ────────────
# Base URL used by customer-side client code AND admin-side server proxy.
PROPA_BACKEND_BASE=https://propabridge-api-gateway-480235407496.us-central1.run.app
NEXT_PUBLIC_PROPA_BACKEND_BASE=https://propabridge-api-gateway-480235407496.us-central1.run.app

# Optional admin token for protected backend admin endpoints (KYC/fraud).
# Backend reads x-admin-token header.
PROPA_BACKEND_ADMIN_TOKEN=

# ─── propabridge-adk (FastAPI AI service on Cloud Run) ──────────────────────
# Used ONLY by the admin section.
PROPA_ADK_BASE=https://propabridge-adk-d7apfb4v6q-uc.a.run.app
PROPA_ADK_ADMIN_KEY=

# ─── /admin/* dashboard login ───────────────────────────────────────────────
# Single-secret guarding /admin/*. Should match PROPA_ADK_ADMIN_KEY so a
# successful login can also call the adk admin API.
ADMIN_DASHBOARD_KEY=

# ─── Agency portal ──────────────────────────────────────────────────────────
# Until /agency/auth/login lands on propabridge-backend, set this to allow
# a single shared password for partner agencies during private preview.
# Leave blank to disable the dev fallback once the backend route ships.
AGENCY_DEV_PASSWORD=

# ─── WhatsApp ───────────────────────────────────────────────────────────────
# E.164 number (no leading +) used for the "Continue on WhatsApp" CTA.
NEXT_PUBLIC_PROPA_WHATSAPP_NUMBER=2348055551300

# ─── Mapbox (polygon drawer in the listing wizard) ──────────────────────────
# Public token (pk.…) from https://account.mapbox.com/access-tokens.
# Without this, the polygon picker shows an empty-state and agencies fall
# back to pasting raw GeoJSON.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Anthropic (admin /api/admin/ai-listing draft generator only) ───────────
# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Gemini (admin AI listing rewrite /api/admin/ai-rewrite, image enhance) ─
# Use the same variables as api-gateway property-audit / autofix (AI Studio).
GEMINI_API_KEY=
# Alternative name supported by rewrite route (either works):
GOOGLE_API_KEY=
# Optional model override for rewrites (default gemini-2.5-flash):
GEMINI_AI_REWRITE_MODEL=

# ─── Sentry (optional, off by default) ──────────────────────────────────────
# Set SENTRY_DSN + uncomment exports in instrumentation.ts and
# sentry.{client,server}.config.ts to activate error tracking.
SENTRY_DSN=

# ─── Gemini image enhancement model (admin photo enhancer) ──────────────────
# Optional override for /api/admin/enhance-image model selection.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
