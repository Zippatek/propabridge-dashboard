# ─── Customer dashboard auth (NextAuth) ─────────────────────────────────────
# Used by Gemini's existing /login (email + password / Google) flow.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── propabridge-backend (Node/Express api-gateway) ─────────────────────────
# Source of truth for users, listings, leads, inspections, inquiries.
# Used by both the customer dashboard and the admin section.
PROPA_BACKEND_BASE=http://localhost:3000

# Optional service token if api-gateway/admin routes require Firebase ID token
# (set to the long-lived admin Firebase ID token, or leave blank if unused).
PROPA_BACKEND_ADMIN_TOKEN=

# ─── propabridge-adk (FastAPI AI service) ───────────────────────────────────
# Used ONLY by the admin section — exposes /api/admin/{overview,conversations,
# leads,funnel,templates,sessions/stream}. Auth via x-admin-key header.
PROPA_ADK_BASE=https://propabridge-adk-d7apfb4v6q-uc.a.run.app
PROPA_ADK_ADMIN_KEY=

# ─── Admin section login ────────────────────────────────────────────────────
# Single-secret guarding /admin/*. Must match PROPA_ADK_ADMIN_KEY in practice
# so a successful login is also able to call the adk admin API.
ADMIN_DASHBOARD_KEY=
